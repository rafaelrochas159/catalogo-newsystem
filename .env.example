# NEW SYSTEM DISTRIBUIDORA - Configuração de Ambiente

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui

# Mercado Pago - Produção
MERCADOPAGO_ACCESS_TOKEN=seu-access-token-do-mercadopago
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=sua-public-key-do-mercadopago
MERCADOPAGO_WEBHOOK_SECRET=seu-webhook-secret-do-mercadopago

# URL do site em produção
NEXT_PUBLIC_SITE_URL=https://catalogo-newsystem.vercel.app
SITE_URL=https://catalogo-newsystem.vercel.app

# Opcional: Configurações de Admin
ADMIN_EMAIL=admin@newsystem.com
ADMIN_EMAILS=admin@newsystem.com
ADMIN_PASSWORD=sua-senha-segura
ADMIN_SESSION_SECRET=defina-um-segredo-longo-e-unico

# AutomaÃ§Ã£o e tracking
INTERNAL_AUTOMATION_SECRET=defina-um-segredo-interno-para-rotas-de-automacao

# WhatsApp API
WHATSAPP_PROVIDER=meta
WHATSAPP_ACCESS_TOKEN=seu-token-da-whatsapp-cloud-api
WHATSAPP_PHONE_NUMBER_ID=seu-phone-number-id
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_NOTIFICATIONS_PHONE=5511999999999
WHATSAPP_SEND_CUSTOMER_CONFIRMATION=false

# Opcional: provedor externo de WhatsApp
WHATSAPP_WEBHOOK_URL=https://seu-provedor-whatsapp.com/send
WHATSAPP_WEBHOOK_TOKEN=token-opcional-do-provedor

# Meta Ads / Conversions API
META_PIXEL_ID=seu-pixel-id
META_CONVERSIONS_API_TOKEN=seu-token-da-conversions-api
META_GRAPH_API_VERSION=v20.0

# Google Analytics 4 Measurement Protocol
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=seu-api-secret
